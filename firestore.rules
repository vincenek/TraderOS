rules_version = '2';

// TrafxOS Firestore security rules.
// CRITICAL: the Pro entitlement (users/{uid}.pro) must NEVER be writable by the
// client — only the Admin SDK in our Netlify Functions can set it. Otherwise a
// user could simply write pro:true and get Pro for free.
service cloud.firestore {
  match /databases/{database}/documents {

    // The user profile doc holds the Pro flag.
    match /users/{uid} {
      // Owner can READ their own profile (to learn if they're Pro)...
      allow read: if request.auth != null && request.auth.uid == uid;
      // ...but NO client can write it. Pro is granted server-side only.
      allow write: if false;

      // Trades are the user's own data — full client read/write for the owner.
      match /trades/{tradeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Payment ledger — server (Admin SDK) only. Used to prevent transaction reuse.
    match /payments/{txId} {
      allow read, write: if false;
    }

    // Feedback — signed-in users may submit, nobody can read back from the client.
    match /feedback/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
